{
  "name": "kendall-nxt",
  "version": "0.1.0",
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.55.0"
  },
  "engines": {
    "node": ">=22 <25",
    "pnpm": "11.5.2"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "doctor": "pnpm run preflight",
    "bootstrap:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap-windows.ps1",
    "setup": "node ./scripts/setup.mjs",
    "setup:js": "pnpm install",
    "setup:py": "uv sync --directory services/supervisor",
    "setup:e2e": "node ./scripts/setup-e2e.mjs",
    "preflight": "node ./scripts/preflight.mjs",
    "preflight:js": "node ./scripts/preflight.mjs js",
    "preflight:python": "node ./scripts/preflight.mjs python",
    "check:docs": "node ./scripts/check-doc-indexes.mjs",
    "doctor:github": "node ./scripts/github-sync-doctor.mjs",
    "dev:dashboard": "pnpm run preflight:js && pnpm --filter @kendall/dashboard dev",
    "dev:supervisor": "pnpm run preflight:python && uv run --directory services/supervisor uvicorn supervisor.api.main:app --host 0.0.0.0 --reload",
    "build:dashboard": "pnpm --filter @kendall/dashboard build",
    "lint:dashboard": "pnpm --filter @kendall/dashboard lint",
    "test:e2e:dashboard": "playwright test",
    "test:e2e:dashboard:controls": "node ./scripts/run-controls-e2e.mjs",
    "test:supervisor": "uv run --directory services/supervisor pytest",
    "check": "pnpm run preflight && pnpm run check:docs && pnpm run build:dashboard && pnpm run test:supervisor"
  }
}
