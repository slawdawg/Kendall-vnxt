{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kendall-nxt.local/schemas/module-contract.schema.json",
  "title": "Runtime Module Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "identity",
    "capability",
    "data_access",
    "actions",
    "trust",
    "memory",
    "privacy",
    "observability",
    "dependencies",
    "installation"
  ],
  "properties": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module_id", "display_name", "version", "publisher"],
      "properties": {
        "module_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "display_name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "release_channel": { "type": "string", "enum": ["dev", "preview", "stable"] }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purpose", "scope_of_agency"],
      "properties": {
        "purpose": { "type": "string", "minLength": 1 },
        "installed_capability_label": { "type": "string" },
        "internal_agents": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "scope_of_agency": {
          "type": "string",
          "enum": ["advisory", "drafting", "internal-action", "external-action", "mixed"]
        }
      }
    },
    "data_access": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "readable_data_classes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "writable_data_classes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "forbidden_data_classes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "advisory_outputs": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "drafting_outputs": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "internal_actions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "external_actions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "forbidden_actions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "trust": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_posture"],
      "properties": {
        "initial_posture": {
          "type": "string",
          "enum": ["shadow", "advisory", "approval-bound", "internal-action-limited"]
        },
        "supported_autonomy_levels": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "approval_required_for": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "blocked_in_release_1": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "readable_memory_classes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "writable_memory_classes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "accepted_correction_types": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "shared_preference_propagation": { "type": "boolean", "default": false }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_only_by_default"],
      "properties": {
        "local_only_by_default": { "type": "boolean" },
        "hosted_eligible_data_classes": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "forbidden_outbound_contexts": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "sanitization_required": { "type": "boolean", "default": true }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status_events": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "audit_event_types": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "metrics": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_core_capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "required_modules": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "optional_modules": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "installation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "setup_steps": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "restart_required": { "type": "boolean", "default": false },
        "migrations": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "compatible_core_versions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    }
  }
}
